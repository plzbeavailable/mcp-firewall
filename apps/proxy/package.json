{
  "name": "@ziwansi/mcp-firewall",
  "version": "0.1.4",
  "description": "MCP Firewall CLI — Security & Observability proxy for MCP (Model Context Protocol)",
  "license": "MIT",
  "author": "ziwansi",
  "repository": {
    "type": "git",
    "url": "https://github.com/plzbeavailable/mcp-firewall"
  },
  "homepage": "https://github.com/ziwansi/mcp-firewall#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "firewall",
    "security",
    "proxy",
    "cli",
    "mcp-server",
    "ai-security"
  ],
  "type": "module",
  "bin": {
    "mcp-firewall": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch --sourcemap",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@ziwansi/mcp-firewall-core": "^0.1.2",
    "@ziwansi/mcp-firewall-config": "^0.1.2",
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@types/node": "^22.0.0"
  }
}
