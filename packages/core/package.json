{
  "name": "@ziwansi/mcp-firewall-core",
  "version": "0.1.2",
  "description": "Core proxy engine, security pipeline, and observability for MCP Firewall",
  "license": "MIT",
  "author": "ziwansi",
  "repository": {
    "type": "git",
    "url": "https://github.com/plzbeavailable/mcp-firewall"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "firewall",
    "security",
    "proxy"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch --sourcemap",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@ziwansi/mcp-firewall-config": "^0.1.2",
    "@modelcontextprotocol/sdk": "^1.9.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
